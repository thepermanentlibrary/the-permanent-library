# The Permanent Library — Indexer Environment Variables

# PostgreSQL connection string
DATABASE_URL=postgresql://permlib:permlib@localhost:5432/permlib

# API server
PORT=3000
HOST=127.0.0.1

# Etherscan V2 API key (REQUIRED)
# Register at https://etherscan.io/register to get a free key.
# One key works for all chains (Ethereum, Polygon, Arbitrum).
# Free tier: 5 calls/sec, 100K calls/day.
# NEVER commit your actual key to source control.
ETHERSCAN_API_KEY=

# Scanner start blocks (optional — defaults are the project's genesis blocks)
# Leave commented out to index all documents from the project's beginning.
# Uncomment and set to 0 to skip all history and start from current block.
# SCAN_START_ETHEREUM=0
# SCAN_START_POLYGON=0
# SCAN_START_ARBITRUM=0

# Search limits
MAX_SEARCH_RESULTS=100

# CORS allowed origins (optional)
# Default: allow all origins (needed for standalone reader opened from local files)
# Production: restrict to your domain
# ALLOWED_ORIGINS=https://thepermanentlibrary.org,https://www.thepermanentlibrary.org
